use dataclean;

CREATE TABLE customertransactions (
    TransactionID INT PRIMARY KEY,
    CustomerName VARCHAR(100),
    Email VARCHAR(100),
    phoneNumber VARCHAR(20),
    PurchaseAmount DECIMAL(10,2),
    PurchaseDate DATE,
    PaymentMethod VARCHAR(50),
    Status VARCHAR(20)
);


